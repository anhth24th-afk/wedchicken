@model List<ChickenKingWeb.Models.User>
@{
    ViewData["Title"] = "Người dùng - Quản trị Chicken King";
    Layout = "_AdminLayout";
}

<div class="space-y-6">
  <h2 class="section-title-italic">Quản lý người dùng (@Model.Count)</h2>
  <div class="bg-white rounded-card shadow-card border-card overflow-hidden">
    <table class="w-full text-left">
      <thead class="bg-neutral-50">
        <tr class="table-header">
          <th class="th-cell-lg">Tên tài khoản</th>
          <th class="th-cell-lg">Vai trò</th>
          <th class="th-cell-lg text-right">Hành động</th>
        </tr>
      </thead>
      <tbody class="divide-y-neutral">
        @foreach (var user in Model)
        {
          <tr class="users-row">
            <td>
              <div class="user-initial">@user.Username.Substring(0, 1).ToUpper()</div>
              <span style="font-weight:700;font-size:1.125rem;">@user.Username</span>
            </td>
            <td>
              <span class="role-badge @(user.Role == "Admin" ? "role-admin" : "role-user")">@user.Role.ToLower()</span>
            </td>
            <td style="text-align:right;">
              @if (user.Role != "Admin")
              {
                <form method="post" asp-action="DeleteUser" onsubmit="return confirm('Xóa người dùng này? Mọi đơn hàng của họ cũng bị xóa.')" style="display:inline-flex;">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="id" value="@user.Id" />
                  <button type="submit" class="icon-btn-del-user">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:1.25rem;height:1.25rem;"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                  </button>
                </form>
              }
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>
