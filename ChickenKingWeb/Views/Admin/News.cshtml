@model List<ChickenKingWeb.Models.News>
@{
    ViewData["Title"] = "Tin tức - Quản trị Chicken King";
    Layout = "_AdminLayout";
}

<div class="space-y-6">
  <div class="flex-between">
    <h2 class="section-title">Quản lý Tin tức (@Model.Count)</h2>
    <button onclick="openAddNewsForm()" class="btn-primary flex-row-gap px-login py-login">
      <i data-lucide="plus" class="w5 h5"></i> Đăng bài mới
    </button>
  </div>

  <div class="admin-products-grid">
    @foreach (var n in Model)
    {
      <div class="admin-product-card">
        <img src="@n.Image" alt="@n.Title" onerror="this.src='https://images.unsplash.com/photo-1562967914-608f82629710?q=80&w=100&h=100&auto=format&fit=crop'" />
        <div class="admin-product-info">
          <h4 style="font-size:1rem;">@n.Title</h4>
          <p class="cat">@n.Category • @n.CreatedAt.ToString("dd/MM/yyyy")</p>
          <p class="desc">@n.Content</p>
        </div>
        <div class="admin-product-actions">
          <button class="icon-btn-edit"
                  data-id="@n.Id" data-title="@n.Title" data-category="@n.Category"
                  data-image="@n.Image" data-content="@n.Content"
                  onclick="openEditNewsForm(this)">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:1rem;height:1rem;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </button>
          <form method="post" asp-action="DeleteNews" onsubmit="return confirm('Xóa bài viết này?')" style="display:flex;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@n.Id" />
            <button type="submit" class="icon-btn-delete">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:1rem;height:1rem;"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
            </button>
          </form>
        </div>
      </div>
    }
  </div>
</div>

<!-- News Form Modal -->
<div id="news-form-modal" class="modal-backdrop hidden">
  <div class="modal-box">
    <div class="flex-between mb-6">
      <h3 class="modal-title" id="news-form-title">Đăng bài mới</h3>
      <button onclick="closeNewsForm()" class="icon-btn-neutral">
        <i data-lucide="x" class="w5 h5"></i>
      </button>
    </div>
    <form method="post" asp-action="SaveNews" class="space-y-4">
      @Html.AntiForgeryToken()
      <input type="hidden" id="news-edit-id" name="Id" value="0" />
      <div class="space-y-2">
        <label class="field-label">Tiêu đề</label>
        <input required id="news-form-title-input" name="Title" class="text-input w-full" />
      </div>
      <div class="space-y-2">
        <label class="field-label">Danh mục</label>
        <select id="news-form-category" name="Category" class="text-input w-full">
          <option>Tin tức</option>
          <option>Sự kiện</option>
          <option>Khuyến mãi</option>
          <option>Ẩm thực</option>
        </select>
      </div>
      <div class="space-y-2">
        <label class="field-label">Hình ảnh (URL)</label>
        <input id="news-form-image" name="Image" class="text-input w-full text-sm" placeholder="URL hình ảnh..." />
      </div>
      <div class="space-y-2">
        <label class="field-label">Nội dung</label>
        <textarea required id="news-form-content" name="Content" class="text-input w-full" rows="5"></textarea>
      </div>
      <button type="submit" class="btn-primary btn-full py-4">
        <span id="news-form-submit-text">Đăng bài</span>
      </button>
    </form>
  </div>
</div>
