<!-- Header -->
<header class="main-header">
  <div class="flex-row-gap">
    <button class="icon-btn-red" onclick="toggleSidebar(true)">
      <i data-lucide="menu" class="w6 h6"></i>
    </button>
    <a href="@Url.Action("Index", "Home")" style="text-decoration:none">
      <span class="brand-title">CHICKEN KING</span>
    </a>
    @if (User.IsInRole("Admin"))
    {
      <a href="@Url.Action("Index", "Admin")" class="admin-badge-btn" style="text-decoration:none">
        <i data-lucide="layout-dashboard" class="w3h3"></i> Quản trị
      </a>
    }
  </div>
  <div class="flex-row-gap">
    <button onclick="setIsCartOpen(true)" class="cart-header-btn relative">
      <i data-lucide="shopping-cart" class="w5 h5 text-primary"></i>
      <span id="header-cart-count" class="cart-badge hidden">0</span>
    </button>
    @if (User.Identity?.IsAuthenticated == true)
    {
      <a href="@Url.Action("Profile", "Account")" class="avatar-btn" style="display:block">
        <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(User.Identity.Name ?? ""))&background=random" alt="User" class="w-full h-full object-cover" />
      </a>
    }
    else
    {
      <a href="@Url.Action("Login", "Account")" class="btn-primary px-login py-login text-sm font-bold shadow-md" style="text-decoration:none">Đăng nhập</a>
    }
  </div>
</header>
