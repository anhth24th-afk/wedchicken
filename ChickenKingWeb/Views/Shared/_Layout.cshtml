<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Chicken King - Ứng dụng đặt gà rán cao cấp" />
  <title>@(ViewData["Title"] ?? "Chicken King - Vua Gà Rán")</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,600;0,700;0,800;1,800&family=Be+Vietnam+Pro:wght@400;500;700&display=swap" rel="stylesheet" />
  <!-- Lucide icons via CDN -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>

<!-- TOAST CONTAINER -->
<div id="toast-container"
     data-toast="@(TempData["Toast"])"
     data-toast-error="@(TempData["ToastError"])"></div>

<div id="main-view" class="min-h-screen bg-surface font-body overflow-x-hidden relative">
  <partial name="_Header" />
  <partial name="_Sidebar" />

  <main class="main-content">
    @RenderBody()
  </main>

  <partial name="_CartPanel" />
  <partial name="_BottomNav" />
</div>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
