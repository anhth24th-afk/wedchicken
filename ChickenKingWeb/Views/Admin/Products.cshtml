@model List<ChickenKingWeb.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm - Quản trị Chicken King";
    Layout = "_AdminLayout";
}

<div class="space-y-6">
  <div class="flex-between">
    <h2 class="section-title">Danh sách Sản phẩm (@Model.Count)</h2>
    <button onclick="openAddProductForm()" class="btn-primary flex-row-gap px-login py-login">
      <i data-lucide="plus" class="w5 h5"></i> Thêm món mới
    </button>
  </div>

  <div class="admin-products-grid">
    @foreach (var p in Model)
    {
      <div class="admin-product-card">
        <img src="@p.Image" alt="@p.Name" onerror="this.src='https://images.unsplash.com/photo-1562967914-608f82629710?q=80&w=100&h=100&auto=format&fit=crop'" />
        <div class="admin-product-info">
          <h4>@p.Name</h4>
          <p class="cat">@p.Category</p>
          <p class="desc">@p.Description</p>
          <p class="price">@p.Price.ToString("N0")đ</p>
        </div>
        <div class="admin-product-actions">
          <button class="icon-btn-edit"
                  data-id="@p.Id" data-name="@p.Name" data-price="@((long)p.Price)"
                  data-category="@p.Category" data-desc="@p.Description" data-image="@p.Image"
                  onclick="openEditProductForm(this)">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:1rem;height:1rem;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </button>
          <form method="post" asp-action="DeleteProduct" onsubmit="return confirm('Xóa sản phẩm này?')" style="display:flex;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@p.Id" />
            <button type="submit" class="icon-btn-delete">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:1rem;height:1rem;"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
            </button>
          </form>
        </div>
      </div>
    }
  </div>
</div>

<!-- Product Form Modal -->
<div id="product-form-modal" class="modal-backdrop hidden">
  <div class="modal-box">
    <div class="flex-between mb-6">
      <h3 class="modal-title" id="product-form-title">Thêm sản phẩm</h3>
      <button onclick="closeProductForm()" class="icon-btn-neutral">
        <i data-lucide="x" class="w5 h5"></i>
      </button>
    </div>
    <form id="product-form" method="post" asp-action="SaveProduct" class="space-y-4">
      @Html.AntiForgeryToken()
      <input type="hidden" id="product-edit-id" name="Id" value="0" />
      <div class="space-y-2">
        <label class="field-label">Tên món</label>
        <input required id="product-form-name" name="Name" class="text-input w-full" />
      </div>
      <div class="grid-2-col">
        <div class="space-y-2">
          <label class="field-label">Giá (VNĐ)</label>
          <input type="number" required id="product-form-price" name="Price" class="text-input w-full" />
        </div>
        <div class="space-y-2">
          <label class="field-label">Danh mục</label>
          <select id="product-form-category" name="Category" class="text-input w-full">
            <option>Gà Rán</option>
            <option>Combo</option>
            <option>Món Phụ</option>
            <option>Đồ Uống</option>
          </select>
        </div>
      </div>
      <div class="space-y-2">
        <label class="field-label">Mô tả</label>
        <textarea id="product-form-desc" name="Description" class="text-input w-full" rows="2"></textarea>
      </div>
      <div class="space-y-2">
        <label class="field-label">Hình ảnh</label>
        <div class="flex-row-gap">
          <input placeholder="URL hình ảnh..." id="product-form-image" name="Image" class="text-input flex-grow text-sm" oninput="updateImagePreview()" />
          <label class="img-upload-btn">
            <i data-lucide="image" class="w5 h5 text-neutral-500"></i>
            <input type="file" class="hidden" accept="image/*" onchange="handleProductFileChange(event)" />
          </label>
        </div>
        <img id="product-form-preview" src="" alt="Preview" class="hidden w-full h-32 object-cover rounded-2xl mt-2" style="height:8rem;object-fit:cover;" />
      </div>
      <button type="submit" class="btn-primary btn-full py-4">
        <span id="product-form-submit-text">Xác nhận thêm</span>
      </button>
    </form>
  </div>
</div>
