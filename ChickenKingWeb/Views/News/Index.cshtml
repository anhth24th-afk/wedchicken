@model List<ChickenKingWeb.Models.News>
@{
    ViewData["Title"] = "Tin tức - Chicken King";
}

<section class="space-y-12 pt-8">
  <div class="menu-header px-2">
    <div>
      <h3 class="menu-title">Tin tức & Sự kiện</h3>
      <div class="menu-underline"></div>
    </div>
  </div>

  <div class="news-grid">
    @if (Model.Count == 0)
    {
      <div class="orders-empty" style="grid-column:1/-1;">Chưa có bài viết nào...</div>
    }
    @foreach (var item in Model)
    {
      <a href="@Url.Action("Details", "News", new { id = item.Id })" class="news-card" style="text-decoration:none;">
        <div class="news-card-img">
          <img src="@item.Image" alt="@item.Title" onerror="this.src='https://images.unsplash.com/photo-1562967914-608f82629710?q=80&w=600&auto=format&fit=crop'" />
          <span class="news-card-cat">@item.Category</span>
        </div>
        <div class="news-card-body">
          <h4 class="news-card-title">@item.Title</h4>
          <p class="news-card-excerpt">@(item.Content.Length > 120 ? item.Content.Substring(0, 120) + "..." : item.Content)</p>
          <p class="news-card-date">@item.CreatedAt.ToString("dd/MM/yyyy")</p>
        </div>
      </a>
    }
  </div>
</section>
